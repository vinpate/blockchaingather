export LC_ALL=C

# Defines
NODE_PID=""
NODE_PID_COMMA=""
UPLOAD=""
STATCMD=""
ITEM=0
TOPDIR=$(mktemp -d ${TMPDIR:-/tmp}/blockchain-gather.XXXXXXXX)
ID="$(cat /etc/hostname)-$(date +'%Y%m%d-%H%M%S')"
RELDIR="blockchain-gather-$ID"
ORIGPWD=$PWD
VERSION=1.0
USERID=$(id -u)

# Helpers

# Takes a string, translates it into something we can use as a log
# file name
n_opt() {
	echo "$1" | tr '/ ' __
}

item_num() {
	printf "%.3d" "$ITEM"
}

logname() {
	echo "$@" | tr -c '[:alnum:]-' '[_*]' | sed 's/_*$//'
}

log() {
	echo "$*" >>"$LOG"
}

info() {
	echo "Info: $*" >&2
	log "$@"
}

warn() {
	echo "Warning: $*" >&2
	log "$@"
}

incr() {
	ITEM=$((ITEM + 1))
}

taskecho() {
	echo "Task: $ITEM: $*"
}

banner() {
	log "--------------------------------"
	log "Item $ITEM: $*"
	log "--------------------------------"
	taskecho "$*"
}

run() {
	incr

	command -v "$1" >/dev/null 2>&1 || return 0

	OLDLOG="$LOG"
	LOG="${DIR}/$(item_num)_$(logname "$@")"
	banner "$@"
	("$@") >>"$LOG" 2>&1
	LOG="$OLDLOG"
}

runpipe_recurse() {
	CMD="$1";
	shift;
	if [ "x$*" = "x" ]; then
		${CMD} 2>&1
	else
		${CMD} 2>&1 | runpipe_recurse "$@"
	fi
}

pipeprint() {
	CMD="$1";
	shift;
	if [ "x$*" = "x" ]; then
		echo ${CMD}
	else
		echo ${CMD} "|" $(pipeprint "$@")
	fi
}

runpipe() {
	incr
	OLDLOG="$LOG"
	LOG="${DIR}/$(item_num)_$(logname "$@")"
	banner $(pipeprint "$@")
	runpipe_recurse "$@" >> ${LOG} 2>&1
	LOG="$OLDLOG"
}

mycat() {
	if [ -r $1 ]; then
		run cat $1
	else
		incr
	fi
}

get_pid() {
	pidir="$(ls /proc/ | grep -E '^[0-9]+$' 2>&1)"
	# NODE_PID detection is now handled automatically in the main script

	if [ -z "${NODE_PID_COMMA}" ]; then
		NODE_PID_COMMA=$(echo "${NODE_PID}" | tr '\n' ' ' | sed 's/ /,/g')
	fi
}

install_required_packages() {
	info "Checking and installing required packages for Ubuntu 22.04+..."
	
	# Check if we're on Ubuntu/Debian
	if ! command -v apt-get >/dev/null 2>&1; then
		warn "This script is designed for Ubuntu 22.04+ with apt package manager"
		warn "Current system may not be fully supported"
		return 1
	fi
	
	# Check Ubuntu version
	if [ -f /etc/os-release ]; then
		. /etc/os-release
		if [ "$ID" = "ubuntu" ]; then
			UBUNTU_VERSION=$(echo "$VERSION_ID" | cut -d. -f1)
			if [ "$UBUNTU_VERSION" -lt 22 ]; then
				warn "This script is optimized for Ubuntu 22.04+. Current version: $VERSION_ID"
				warn "Some features may not work correctly"
			fi
		fi
	fi
	
	# All required packages for Ubuntu 22.04+ blockchain node diagnostics
	REQUIRED_PACKAGES="procps net-tools util-linux coreutils iproute2 sysstat iotop htop lvm2 nvme-cli lsof pciutils jq curl wget psmisc dnsutils"
	
	# Check which packages are missing
	missing_packages=""
	for package in $REQUIRED_PACKAGES; do
		# Check if command exists or package is installed
		if ! command -v "$package" >/dev/null 2>&1 && ! dpkg -l "$package" >/dev/null 2>&1; then
			missing_packages="$missing_packages $package"
		fi
	done
	
	if [ -n "$missing_packages" ]; then
		info "Installing missing packages:$missing_packages"
		
		# Update package lists
		info "Updating package lists..."
		apt update
		
		# Install missing packages
		info "Installing packages..."
		apt install -y $missing_packages
		
		if [ $? -eq 0 ]; then
			info "Successfully installed required packages"
		else
			warn "Some packages failed to install. The script may not work completely."
		fi
	else
		info "All required packages are already installed"
	fi
}

check_tools() {
	missing=
	for command in systemctl journalctl ps netstat ss; do
		if [ ! $(command -v $command) ]; then
			missing="$missing$command "
		fi
	done
	if [ -n "$missing" ]; then
		echo "#######################################################"
		echo "Some binaries are missing from PATH, the results might"
		echo "not be complete:"
		echo ""
		echo "    $missing"
		echo ""
		echo "Please amend your PATH and run again."
		echo "#######################################################"
		sleep 10
	fi
}

show_packages() {
	run dpkg --list "$@"
	run dpkg --status "$@"
	run rpm --query --all "$@"
	run rpm --query --all --info "$@"
}

show_limits() {
	# Get the first blockchain process PID, or use self if none found
	if [ -n "$NODE_PID" ]; then
		pid=$(echo $NODE_PID | awk '{print $1;}')
	else
		pid=$$
	fi
	file="/proc/$pid/limits"

	incr

	OLDLOG="$LOG"
	LOG="${DIR}/$(item_num)_limits"
	banner limits
	log "$file"
	cat "$file" >> ${LOG} 2>&1
	LOG="$OLDLOG"
}

blockdev_cat() {
	echo -n >>${LOG} "$1:"
	cat "$1" >> ${LOG} 2>&1
}

call_blockdev() {
	incr

	OLDLOG="$LOG"
	LOG="${DIR}/$(item_num)_blockdev_info_$(logname "$1")"
	banner "blockdev info $1"
	blockdev_cat "$1/device/model"
	blockdev_cat "$1/queue/logical_block_size"
	blockdev_cat "$1/queue/physical_block_size"
	blockdev_cat "$1/queue/read_ahead_kb"
	blockdev_cat "$1/queue/minimum_io_size"
	blockdev_cat "$1/queue/optimal_io_size"
	LOG="$OLDLOG"
}

nvme_diagnostics() {
	incr
	OLDLOG="$LOG"
	LOG="${DIR}/$(item_num)_nvme_diagnostics"
	banner "NVMe Drive Diagnostics"
	
	# Check if nvme-cli is available
	if ! command -v nvme >/dev/null 2>&1; then
		log "nvme-cli not available, skipping NVMe diagnostics"
		return 0
	fi
	
	# Get NVMe drives
	nvme_drives=$(lsblk -o NAME | grep '^nvme' | sort)
	
	for nvme_drive in $nvme_drives; do
		drive_path="/dev/$nvme_drive"
		log "=== NVMe Drive: $drive_path ==="
		
		# Basic NVMe info
		run nvme id-ns --human-readable "$drive_path"
		
		# LBA Format information
		run nvme id-ns --human-readable "$drive_path" | grep '^LBA Format'
		
		# Detailed JSON analysis if jq is available
		if command -v jq >/dev/null 2>&1; then
			# Get JSON output and validate it before processing
			json_output=$(nvme id-ns -o json "$drive_path" 2>/dev/null)
			if echo "$json_output" | jq empty 2>/dev/null; then
				# JSON is valid, process it
				echo "$json_output" | jq --arg drive "$drive_path" '{
					"drive": $drive,
					"currently_active": {
						"index": .flbas,
						"data_size": .lbafs[.flbas].ds,
						"relative_performance": .lbafs[.flbas].rp
					},
					"optimal_format": (
						.lbafs | to_entries |
						(map(select(.value.rp == 0)) | if length > 0 then . else .lbafs | to_entries end) |
						max_by(.value.ds) | {
							"index": .key,
							"data_size": .value.ds,
							"relative_performance": .value.rp
						}
					),
					"is_optimal": (
						.flbas == (
							.lbafs | to_entries |
							(map(select(.value.rp == 0)) | if length > 0 then . else .lbafs | to_entries end) |
							max_by(.value.ds) | .key
						)
					)
				}' >> "$LOG" 2>&1
			else
				log "Warning: Invalid JSON output from nvme id-ns for $drive_path"
				log "Raw output: $json_output"
			fi
		fi
		
		log ""
	done
	
	LOG="$OLDLOG"
}

zfs_diagnostics() {
	incr
	OLDLOG="$LOG"
	LOG="${DIR}/$(item_num)_zfs_diagnostics"
	banner "ZFS Diagnostics"
	
	# Check if ZFS is available
	if command -v zfs >/dev/null 2>&1; then
		run zfs version
		run zpool list
		run zfs list
		run zpool status
		run zfs get all
		run zpool get all
		run zfs get -H -o name,property,value,source all | head -50
		run zpool get -H -o name,property,value,source all | head -50
	else
		log "ZFS not available on this system"
	fi
	
	LOG="$OLDLOG"
}

generate_summary() {
	incr
	OLDLOG="$LOG"
	LOG="${DIR}/$(item_num)_summary_report"
	banner "Generating Summary Report"
	
	# Create a comprehensive summary file
	SUMMARY_FILE="${DIR}/SYSTEM_SUMMARY.txt"
	
	{
		echo "==============================================================================="
		echo "BLOCKCHAIN NODE SYSTEM SUMMARY REPORT"
		echo "==============================================================================="
		echo "Generated: $(date)"
		echo "Hostname: $(hostname)"
		echo "Script Version: $VERSION"
		echo ""
		
		# System Overview
		echo "🖥️  SYSTEM OVERVIEW"
		echo "==============================================================================="
		# Find files by command name instead of hardcoded numbers
		LSB_FILE=$(find "${DIR}" -name "*lsb_release_-a" | head -1)
		if [ -r "$LSB_FILE" ]; then
			echo "Operating System:"
			grep -A 3 "lsb_release -a" "$LSB_FILE" | grep -E "(Description|Release|Codename)" | sed 's/^/  /'
		fi
		
		UNAME_FILE=$(find "${DIR}" -name "*uname_-a" | head -1)
		if [ -r "$UNAME_FILE" ]; then
			echo "Kernel:"
			cat "$UNAME_FILE" | tail -1 | sed 's/^/  /'
		fi
		
		UPTIME_FILE=$(find "${DIR}" -name "*uptime" | head -1)
		if [ -r "$UPTIME_FILE" ]; then
			echo "Uptime:"
			cat "$UPTIME_FILE" | tail -1 | sed 's/^/  /'
		fi
		echo ""
		
		# Hardware Information
		echo "💻 HARDWARE SPECIFICATIONS"
		echo "==============================================================================="
		CPUINFO_FILE=$(find "${DIR}" -name "*cat__proc_cpuinfo" | head -1)
		if [ -r "$CPUINFO_FILE" ]; then
			echo "CPU Information:"
			grep -A 5 "processor.*: 0" "$CPUINFO_FILE" | grep -E "(model name|cpu cores|siblings)" | sed 's/^/  /'
		fi
		
		# CPU Performance Data (if available)
		LSCPU_FILE=$(find "${DIR}" -name "*lscpu" | head -1)
		if [ -r "$LSCPU_FILE" ]; then
			echo "CPU Performance:"
			grep -E "(CPU.*scaling MHz|CPU max MHz|CPU min MHz)" "$LSCPU_FILE" | sed 's/^/  /'
		fi
		
		CPUPOWER_FILE=$(find "${DIR}" -name "*cpupower_monitor" | head -1)
		if [ -r "$CPUPOWER_FILE" ]; then
			echo "CPU Usage & Idle States:"
			grep -A 5 "Mperf" "$CPUPOWER_FILE" | head -3 | sed 's/^/  /'
		fi
		
		FREE_FILE=$(find "${DIR}" -name "*free_-m" | head -1)
		if [ -r "$FREE_FILE" ]; then
			echo "Memory:"
			grep -A 3 "free -m" "$FREE_FILE" | grep -E "(Mem:|total|used|available)" | sed 's/^/  /'
		fi
		
		DF_FILE=$(find "${DIR}" -name "*df_-h" | head -1)
		if [ -r "$DF_FILE" ]; then
			echo "Storage:"
			grep -A 10 "df -h" "$DF_FILE" | sed 's/^/  /'
		fi
		echo ""
		
		# Blockchain Node Information
		echo "⛓️  BLOCKCHAIN NODE STATUS"
		echo "==============================================================================="
		echo "Active Blockchain Processes:"
		ps aux | grep -E "(op-reth|op-node|geth|erigon|parity|besu|nethermind)" | grep -v grep | head -5 | awk '{print "  PID:", $2, "CPU:", $3"%", "MEM:", $4"%", "VSZ:", $5, "RSS:", $6, "CMD:", $11}' | sed 's/^/  /'
		
		echo "Top Resource Consumers:"
		ps -o pid,user,pmem,vsz,rss,comm --sort=-pmem | grep -E "(op-reth|op-node)" | head -3 | awk '{print "  PID:", $1, "USER:", $2, "MEM:", $3"%", "VSZ:", $4, "RSS:", $5, "CMD:", $6}' | sed 's/^/  /'
		echo ""
		
		# Docker Information
		echo "🐳 DOCKER CONTAINER STATUS"
		echo "==============================================================================="
		echo "Running Containers:"
		docker ps -a | grep -E "(CONTAINER|Up)" | head -5 | sed 's/^/  /'
		echo ""
		
		# Network Services
		echo "🌐 NETWORK SERVICES"
		echo "==============================================================================="
		
		# Enhanced blockchain port detection with service grouping
		echo "Blockchain Services by Container/Process:"
		
		# Group by Docker containers
		if command -v docker >/dev/null 2>&1; then
			echo "  📦 Docker Containers:"
			docker ps --format "table {{.Names}}\t{{.Ports}}" | grep -E "(eth|geth|erigon|parity|besu|nethermind|bitcoin|foundry|anvil|reth|op-|base|optimism|arbitrum|polygon|avax|solana|cardano|polkadot|cosmos|near|algorand|tezos|chainlink|the-graph|indexer|node|validator|miner|consensus)" | while read line; do
				echo "    $line" | sed 's/^/      /'
			done
			echo ""
		fi
		
		# Group by running processes with enhanced detection
		echo "  🔧 Running Processes:"
		ps aux | grep -E "(geth|erigon|parity|besu|nethermind|bitcoin|foundry|anvil|reth|op-|base|optimism|arbitrum|polygon|avax|solana|cardano|polkadot|cosmos|near|algorand|tezos|chainlink|the-graph|indexer|node|validator|miner|consensus)" | grep -v grep | while read line; do
			process_name=$(echo "$line" | awk '{print $11}' | sed 's/.*\///')
			pid=$(echo "$line" | awk '{print $2}')
			user=$(echo "$line" | awk '{print $1}')
			cpu=$(echo "$line" | awk '{print $3}')
			mem=$(echo "$line" | awk '{print $4}')
			
			# Get ports for this process
			ports=$(netstat -tulnp 2>/dev/null | grep "$pid/" | grep -oE ':[0-9]+' | cut -d: -f2 | sort -u | tr '\n' ',' | sed 's/,$//')
			
			# Get command line arguments for port detection
			cmd_line=$(echo "$line" | awk '{for(i=11;i<=NF;i++) printf "%s ", $i}' | sed 's/ $//')
			cmd_ports=$(echo "$cmd_line" | grep -oE '(port|rpc|ws|http|metrics|discovery|authrpc)\.port[=:][0-9]+|--port[=:][0-9]+|--rpc\.port[=:][0-9]+|--ws\.port[=:][0-9]+|--metrics[=:][0-9]+|--discovery\.port[=:][0-9]+|--authrpc\.port[=:][0-9]+' | grep -oE '[0-9]+' | tr '\n' ',' | sed 's/,$//')
			
			if [ -n "$ports" ] || [ -n "$cmd_ports" ]; then
				all_ports=$(echo "$ports,$cmd_ports" | tr ',' '\n' | grep -v '^$' | sort -u | tr '\n' ',' | sed 's/,$//')
				echo "    $process_name (PID: $pid, User: $user, CPU: ${cpu}%, MEM: ${mem}%) - Ports: $all_ports" | sed 's/^/      /'
				echo "      Command: $cmd_line" | sed 's/^/        /'
			fi
		done
		echo ""
		
		# All detected blockchain ports (TCP and UDP)
		echo "  📊 All Blockchain Ports (TCP & UDP):"
		ALL_BLOCKCHAIN_PORTS=$(netstat -tulnp | grep -E ':(8[0-9]{3}|9[0-9]{3}|30303|6060|7300|7301|7545|8545|8546|8551|9222)' | grep -oE ':[0-9]+' | cut -d: -f2 | sort -u | tr '\n' ',' | sed 's/,$//')
		if [ -n "$ALL_BLOCKCHAIN_PORTS" ]; then
			echo "    $ALL_BLOCKCHAIN_PORTS" | sed 's/^/      /'
		fi
		echo ""
		
		# Ultimate blockchain port detection function (TCP and UDP)
		detect_blockchain_ports() {
			# Method 1: Port range detection (8xxx-9xxx + common blockchain ports) - includes UDP
			PORTS1=$(netstat -tulnp | grep -E ':(8[0-9]{3}|9[0-9]{3}|30303|6060|7300|7301|7545|8545|8546|8551|9222)' | grep -oE ':[0-9]+' | cut -d: -f2 | sort -u)
			
			# Method 2: Docker container detection
			PORTS2=$(docker ps --format '{{.Ports}}' 2>/dev/null | grep -E '(eth|geth|erigon|parity|besu|nethermind|bitcoin|foundry|anvil|reth|op-|base|optimism|arbitrum|polygon|avax|solana|cardano|polkadot|cosmos|near|algorand|tezos|chainlink|the-graph|indexer|node|validator|miner|consensus)' | grep -oE '[0-9]+->[0-9]+' | cut -d: -f1 | sort -u)
			
			# Method 3: Process command line detection
			PORTS3=$(ps aux | grep -E '(geth|erigon|parity|besu|nethermind|bitcoin|foundry|anvil|reth|op-|base|optimism|arbitrum|polygon|avax|solana|cardano|polkadot|cosmos|near|algorand|tezos|chainlink|the-graph|indexer|node|validator|miner|consensus)' | grep -v grep | grep -oE '(port|rpc|ws|http|metrics|discovery|authrpc)\.port[=:][0-9]+|--port[=:][0-9]+|--rpc\.port[=:][0-9]+|--ws\.port[=:][0-9]+|--metrics[=:][0-9]+|--discovery\.port[=:][0-9]+|--authrpc\.port[=:][0-9]+' | grep -oE '[0-9]+' | sort -u)
			
			# Combine all methods, remove duplicates, and format
			echo "$PORTS1 $PORTS2 $PORTS3" | tr ' ' '\n' | grep -v '^$' | sort -u | tr '\n' '|' | sed 's/|$//'
		}
		
		# Use the enhanced detection
		BLOCKCHAIN_PORTS=$(detect_blockchain_ports)
		
		echo "Active UFW Ports (Blockchain & Key Services):"
		if [ -n "$BLOCKCHAIN_PORTS" ]; then
			ufw status numbered | grep -E "($BLOCKCHAIN_PORTS|443|9100)" | grep -v "22/tcp" | sed 's/^/  /'
		else
			ufw status numbered | grep -E "(443|9100)" | sed 's/^/  /'
		fi
		echo ""
		
		# Enhanced service mapping (TCP and UDP)
		echo "  🔍 Detailed Service Mapping:"
		
		# Map each detected port to its service (both TCP and UDP)
		if [ -n "$BLOCKCHAIN_PORTS" ]; then
			IFS='|' read -ra PORTS_ARRAY <<< "$BLOCKCHAIN_PORTS"
			for port in "${PORTS_ARRAY[@]}"; do
				if [ -n "$port" ]; then
					# Find what's listening on this port (both TCP and UDP)
					netstat -tulnp | grep ":$port " | while read service_info; do
						if [ -n "$service_info" ]; then
							proto=$(echo "$service_info" | awk '{print $1}')
							address=$(echo "$service_info" | awk '{print $4}')
							process=$(echo "$service_info" | awk '{print $7}')
							
							echo "    Port $port: $proto $address -> $process" | sed 's/^/      /'
						fi
					done
				fi
			done
		fi
		echo ""
		
		echo "All Services Listening:"
		netstat -tuln | grep LISTEN | sed 's/^/  /'
		echo ""
		
		# Storage Analysis
		echo "💾 STORAGE ANALYSIS"
		echo "==============================================================================="
		NVME_FILE=$(find "${DIR}" -name "*nvme_diagnostics" | head -1)
		if [ -r "$NVME_FILE" ]; then
			echo "NVMe Drive Status:"
			# Extract drive information more comprehensively
			grep -A 100 "NVMe Drive Diagnostics" "$NVME_FILE" | grep -E "(drive.*nvme|is_optimal.*false|is_optimal.*true)" | sed 's/^/  /'
		fi
		
		echo "Block Devices:"
		# Use lsblk -e 7 directly to exclude loop devices (major number 7)
		lsblk -e 7 | sed 's/^/  /'
		echo ""
		
		# Key Findings
		echo "🔍 KEY FINDINGS"
		echo "==============================================================================="
		
		# Check for high memory usage
		MEMORY_USAGE=$(ps -o pid,user,pmem,comm --sort=-pmem | grep "op-reth" | awk '{print $3}' | head -1 | sed 's/%//' 2>/dev/null)
		# Sanitize the memory usage to ensure it's a single integer
		MEMORY_USAGE=$(echo "$MEMORY_USAGE" | tr -d '\n\r' | awk '{print $1}')
		if [ -n "$MEMORY_USAGE" ] && [ "$MEMORY_USAGE" -gt 80 ] 2>/dev/null; then
			echo "⚠️  HIGH MEMORY USAGE: op-reth using ${MEMORY_USAGE}% of system memory"
		fi
		
		# Check NVMe optimization
		NVME_FILE=$(find "${DIR}" -name "*nvme_diagnostics" | head -1)
		if [ -r "$NVME_FILE" ]; then
			OPTIMAL_COUNT=$(grep -c "is_optimal.*false" "$NVME_FILE" 2>/dev/null || echo "0")
			# Sanitize the count to ensure it's a single integer
			OPTIMAL_COUNT=$(echo "$OPTIMAL_COUNT" | tr -d '\n\r' | awk '{print $1}')
			if [ -n "$OPTIMAL_COUNT" ] && [ "$OPTIMAL_COUNT" -gt 0 ] 2>/dev/null; then
				echo "⚠️  NVMe OPTIMIZATION: $OPTIMAL_COUNT drive(s) not using optimal sector size (4KB)"
			fi
		fi
		
		# Check disk usage
		ROOT_USAGE=$(df -h | grep "/dev/md0" | awk '{print $5}' | sed 's/%//' 2>/dev/null)
		# Sanitize the disk usage to ensure it's a single integer
		ROOT_USAGE=$(echo "$ROOT_USAGE" | tr -d '\n\r' | awk '{print $1}')
		if [ -n "$ROOT_USAGE" ] && [ "$ROOT_USAGE" -gt 80 ]; then
			echo "⚠️  HIGH DISK USAGE: Root filesystem ${ROOT_USAGE}% full"
		fi
		
		# Check uptime
		UPTIME_DAYS=$(uptime | grep -o "up [0-9]* days" | grep -o "[0-9]*" 2>/dev/null)
		# Sanitize the uptime to ensure it's a single integer
		UPTIME_DAYS=$(echo "$UPTIME_DAYS" | tr -d '\n\r' | awk '{print $1}')
		if [ -n "$UPTIME_DAYS" ] && [ "$UPTIME_DAYS" -gt 30 ]; then
			echo "✅ EXCELLENT STABILITY: System uptime ${UPTIME_DAYS} days"
		fi
		echo ""
		
		echo "==============================================================================="
		echo "END OF SUMMARY REPORT"
		echo "==============================================================================="
		
	} > "$SUMMARY_FILE"
	
	log "Summary report generated: $SUMMARY_FILE"
	LOG="$OLDLOG"
}

