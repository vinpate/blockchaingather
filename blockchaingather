usage() {
	cat <<_EOF_
Usage: $0 [-h] [-p] [-s] [-u identifier]

Blockchain-gather gathers various system information into a single tar-ball.

 -h                   Show this help text
 -p                   Perform CPU performance monitoring (frequencies, idle states, power management)
 -s                   Run only storage diagnostics (NVMe, ZFS, disk info)
 -u <identifier>      Upload generated gather to filebin.nirvanalabs.io (TEMPORARILY DISABLED)

The script automatically detects all blockchain node processes and their
arguments. No additional configuration is needed.
_EOF_
	exit $1
}

##############################
# Proper execution starts here
##############################

while getopts hpsu: opt
do
	case $opt in
	p) PERF="TRUE" ;;
	s) STORAGE="TRUE" ;;
	u) UPLOAD=$OPTARG ;; # TEMPORARILY DISABLED
	h)
		usage 0
		;;
	*)
		usage 1
		;;
	esac
done

shift $((OPTIND - 1))

if [ $# -gt 0 ]
then
	info "Unknown argument: $1"
	usage 1
fi

STATCMD=$NAME

# Set up environment
DIR="$TOPDIR/$RELDIR"
LOG="$DIR/blockchain-gather.log"

mkdir -p "$DIR"
cd "$DIR"

cleanup () {
	rm -rf "$TOPDIR"
	exit 1
}
trap cleanup EXIT 2

info "Blockchain-gather version: $VERSION"
info "Invoked by: $USERID"
info "Command line: $*"
info "Working directory: $DIR"

if [ "${USERID}" -ne "0" ]; then
	echo "#######################################################"
	echo "Running as non-root, the results might not be complete."
	echo "Please run again as root."
	echo "#######################################################"
	sleep 10
fi

# Install required packages first
install_required_packages

check_tools

if [ ! $(command -v pidof) ] || [ ! $(command -v pgrep) ]; then
	 get_pid
fi

# Node type detection is now automatic

# If storage-only mode, run only storage diagnostics and exit
if [ "$STORAGE" = "TRUE" ]; then
	info "Running in storage-only mode"
	run date
	run hostname
	run uname -a
	run lsb_release -a
run df -h
run lsblk
nvme_diagnostics
	zfs_diagnostics
	run lspci -vv -nn -k
	cd "$ORIGPWD"
	TGZ="blockchain-gather-storage.${ID}.tar.gz"
	tar czf "$TGZ" -C "$TOPDIR" "$RELDIR"
	echo "==============================================================================="
	echo "Storage diagnostics complete. Please submit the file: $TGZ"
	echo "==============================================================================="
	exit 0
fi
run date
run dmesg
run dmesg -T
run hostname
mycat /etc/hostname
mycat /var/log/dmesg
mycat /proc/cpuinfo
mycat /proc/version
runpipe "ps aux" "egrep (geth|erigon|parity|besu|nethermind|bitcoin|ethereum|blockchain|node|op-reth|op-node|reth|anvil|foundry)"
runpipe "netstat -np" "wc -l"
runpipe "netstat -np" "grep ESTABLISHED" "wc -l"
run uptime
run free -m
runpipe "ps axo pid,user,pmem,vsz,rss,exe,comm k -pmem" "head -n 11"
run vmstat -w 1 3
run mpstat -P ALL 1 3
run iostat 1 3
run lsb_release -a
mycat /etc/redhat-release
run sysctl -a
run getenforce
run umask

show_packages \
	'geth*' \
	'erigon*' \
	'parity*' \
	'besu*' \
	'nethermind*' \
	'bitcoin*' \
	'*ethereum*' \
