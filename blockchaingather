	'*jemalloc*' \
	'*pcre*' \
	'*openssl*'\
	'*libssl*'\
	'nvme-cli' \
	'jq' \
	ca-certificates

run systemctl cat \
	ethereum \
	geth \
	erigon \
	parity \
	besu \
	nethermind \
	bitcoin \
	op-reth \
	op-node \
	reth

# Docker container information
run docker ps -a
run docker images | head -20
run docker stats --no-stream
run docker system df

run netstat -s
run ip a
run ip n
run ip r
run ip -s l
run ifconfig
run uname -a
run mount
runpipe mount sort
run df -h
run fdisk -l
run lvdisplay -vm
run vgdisplay -v
run pvdisplay -v

NETSTAT="/bin/netstat"
run "$NETSTAT" -nlpt
run "$NETSTAT" -np

# Comprehensive Network Diagnostics
banner "UFW Firewall Status"
run ufw status numbered

banner "All Listening Ports"
run netstat -tuln | grep LISTEN

banner "Network Interface Statistics"
run ip -s link show

banner "Routing Table"
run ip route show

banner "ARP Table"
run ip neigh show

banner "Blockchain Network Analysis"
run netstat -tulnp | grep -E "(op-reth|op-node|geth|erigon|parity|besu|nethermind|bitcoin|foundry|anvil|docker-prox)"

banner "Network Connections by Process"
run netstat -tulnp | awk 'NR>2 {print $7}' | cut -d/ -f2 | sort | uniq -c | sort -nr | head -10

banner "Detailed Process Information"
# Get top processes by connection count
TOP_PROCESSES=$(netstat -tulnp | awk 'NR>2 {print $7}' | cut -d/ -f2 | sort | uniq -c | sort -nr | head -10 | awk '{print $2}' | grep -v '^$')

for process in $TOP_PROCESSES; do
    if [ -n "$process" ]; then
        log "=== Process: $process ==="
        # Get process details
        run ps aux | grep "$process" | grep -v grep | head -3
        # Get memory and CPU usage
        run ps -o pid,user,pmem,pcpu,vsz,rss,comm,cmd --sort=-pmem | grep "$process" | head -3
        # Get network connections for this process
        run netstat -tulnp | grep "$process" | head -5
        log ""
    fi
done

mycat /etc/init.d/ethereum
mycat /etc/default/ethereum
mycat /etc/sysconfig/ethereum
mycat /sys/kernel/mm/transparent_hugepage/enabled
mycat /sys/kernel/mm/redhat_transparent_hugepage/enabled
mycat /proc/user_beancounters
mycat /proc/meminfo
mycat /proc/crypto
mycat /proc/sys/net/ipv4/tcp_tw_reuse
for pid in ${NODE_PID}; do
	run cat -v /proc/$pid/cmdline
	mycat /proc/$pid/cgroup
done
show_limits

mycat /etc/hosts
mycat /etc/resolv.conf
mycat /etc/nsswitch.conf

run find /usr/local -name "*ethereum*" -o -name "*geth*" -o -name "*erigon*"

# lsof
for pid in ${NODE_PID}; do
	run lsof -p $pid
done

for a in /sys/block/*; do
	call_blockdev "$a"
done

run lsblk

# Always include NVMe diagnostics
nvme_diagnostics

for a in /var/log/messages /var/log/syslog; do
	if [ -r "$a" ]; then
		run egrep -i "(ethereum|geth|erigon|parity|besu|nethermind|bitcoin|blockchain|node|op-reth|op-node|reth|anvil|foundry|base|optimism|arbitrum|polygon)" "$a"
	else
		incr
	fi
done

# ip tables
if  (lsmod | grep ip_tables > /dev/null); then
	run iptables-save
fi

if  (lsmod | grep ip6_tables > /dev/null); then
	run ip6tables-save
fi

# maps
for pid in ${NODE_PID}; do
	runpipe "awk '$2 ~ \"rw\"' /proc/$pid/maps" "wc -l"
done

# Pick up the basic memory offset the text segments are in.
for pid in ${NODE_PID}; do
	run grep "r-xp" /proc/$pid/maps
done

# Get node memory maps
for pid in ${NODE_PID}; do
	mycat /proc/$pid/smaps
	mycat /proc/$pid/status
done

# CPU Performance Monitoring (always included in full mode)
if [ "$STORAGE" != "TRUE" ]; then
	# Check current CPU frequencies & scaling
	run lscpu | grep CPU | grep MHz
	# Check cpupower to see CPU idle states and power management
	run cpupower monitor | head -20
	# Check CPU governor settings
	run cpupower frequency-info
	# Check CPU topology and cache info
	run lscpu -e
fi

# rc.local
if [ -f /etc/rc.local ]; then
	run cat /etc/rc.local
fi

run lspci -vv -nn -k

# ZFS diagnostics (always included in full mode)
if [ "$STORAGE" != "TRUE" ]; then
	zfs_diagnostics
fi

# Generate comprehensive summary report (only for full mode, not storage-only)
if [ "$STORAGE" != "TRUE" ]; then
	generate_summary
fi

